# Meta Graph API / Business Messaging
META_ACCESS_TOKEN=seu_access_token_com_permissoes
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
META_GRAPH_API_VERSION=v25.0
META_TEST_EVENT_CODE=TESTxxxx

# WhatsApp Business / CTWA
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_waba_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=defina_um_token_secreto

# Opcional: se já souber o dataset, pode fixar aqui
META_DATASET_ID=

# Database (Neon / Vercel Postgres)
POSTGRES_URL=postgresql://...

# App Security
APP_SECRET=sua_senha_secreta

# App URL
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app
